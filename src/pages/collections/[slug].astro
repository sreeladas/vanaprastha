---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionPage from '../../components/react/CollectionPage';
import { getCollection } from 'astro:content';

const { slug } = Astro.params;
const allCollections = await getCollection('collections');
const entry = allCollections.find((c) => c.id === slug);

if (!entry) return Astro.redirect('/404');

const imageBaseUrl = import.meta.env.PUBLIC_IMAGE_BASE_URL || '/images';
---

<BaseLayout title={entry.data.title}>
  <CollectionPage
    title={entry.data.title}
    blurb={entry.body || ''}
    heroImage={entry.data.heroImage}
    heroFocus={entry.data.heroFocus}
    items={entry.data.items || []}
    slug={slug!}
    imageBaseUrl={imageBaseUrl}
    client:load
  />
</BaseLayout>
